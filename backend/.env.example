# Server
PORT=3000

# JWT (Identity Context)
# JWT_EXPIRES_IN: thời hạn token. Ví dụ: 1d, 8h, 30m
JWT_SECRET=generate_via_crypto_randomBytes_64_toString_hex
JWT_EXPIRES_IN=1d

# MongoDB (NoSQL)
#Dev thì xài Local MongoDB Server (Quản lý bằng Compass)
#Production (self-host): mongodb://root:<password>@mongo:27017/elearning_db?authSource=admin
#Production (Atlas):     mongodb+srv://<user>:<password>@cluster.mongodb.net/elearning_db
MONGO_URI=replace_with_your_mongo_uri

# MongoDB Auth - chỉ cần khi production self-host (thêm vào docker-compose)
# MONGO_ROOT_USER=replace_with_mongo_root_user
# MONGO_ROOT_PASSWORD=replace_with_mongo_root_password

# Oracle (SQL)
ORACLE_USER=replace_with_your_oracle_user
ORACLE_PASSWORD=replace_with_your_oracle_password
ORACLE_SYS_PASSWORD=replace_with_your_oracle_sys_password
ORACLE_CONNECTION_STRING=replace_with_your_connection_string 
# Dev:        127.0.0.1:1521/XEPDB1
# Production: oracle:1521/XEPDB1

# Redis (Cache)
# Dev:        127.0.0.1
# Production: redis
REDIS_HOST=replace_with_your_redis_host 
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_your_redis_password_if_any